{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "content:manifest": "node scripts/generate-content-manifest.mjs",
    "predev": "npm run content:manifest",
    "prebuild": "npm run content:manifest",
    "dev": "next dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "build:worker:prod": "NODE_ENV=production opennextjs-cloudflare build",
    "preview": "npm run build:worker && wrangler dev --local --env-interface CloudflareEnv",
    "preview:prod": "npm run build:worker:prod && wrangler dev --local --env-interface CloudflareEnv",
    "deploy": "npm run build:worker:prod && wrangler deploy --keep-vars",
    "deploy:preview": "npm run build:worker && wrangler deploy --keep-vars --env preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint",
    "optimize": "npm run build && npm run cf-typegen",
    "clean": "rm -rf .next .open-next/node_modules .open-next/.next"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "^4.0.1",
    
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.81.1"
  }
}
