{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/blog/layout,_N_T_/blog/broadcast-industry-has-software-problem/layout,_N_T_/blog/broadcast-industry-has-software-problem/page,_N_T_/blog/broadcast-industry-has-software-problem"},"segmentPaths":["/_tree","/_full","/blog/broadcast-industry-has-software-problem/__PAGE__","/blog/broadcast-industry-has-software-problem","/blog","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"unbounded_bd0b8503-module__HKhjHW__variable manrope_249fa6-module__aN1UAW__variable ibm_plex_mono_da532ca3-module__VyszMW__variable\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/99e609270109b47d-s.p.16-z~2sp29ex6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/a343f882a40d2cc9-s.p.0kho-wj7-y-w1.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/b59689b1142d37ce-s.p.0f8~qglggluhl.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/effe91970fc4db64-s.p.07ig5l8azj~hy.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/icon-purple.svg\" as=\"image\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/12ee8a7~m5431.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/05tsy9pxtuyv0.js\"/><script src=\"/_next/static/chunks/0pqt~8bl3ukh4.js\" async=\"\"></script><script src=\"/_next/static/chunks/0257pdz1-imal.js\" async=\"\"></script><script src=\"/_next/static/chunks/0yoi6g0rt32bk.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-0lirhqftrg8d-.js\" async=\"\"></script><script src=\"/_next/static/chunks/148d-9g_w8i0~.js\" async=\"\"></script><script src=\"/_next/static/chunks/04mq052otkkl9.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0q77_8lbj.p8k.js\" async=\"\"></script><script src=\"/_next/static/chunks/08y1d-jmw72iw.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>The Broadcast Industry Has a Software Problem - Sonicverse</title><meta name=\"description\" content=\"Explore how open source solutions can resolve the software challenges in the broadcast industry for improved efficiency and innovation.\"/><link rel=\"manifest\" href=\"/site.webmanifest\"/><link rel=\"canonical\" href=\"https://sonicverse.eu/blog/broadcast-industry-has-software-problem\"/><meta property=\"og:title\" content=\"The Broadcast Industry Has a Software Problem | Sonicverse\"/><meta property=\"og:description\" content=\"Explore how open source solutions can resolve the software challenges in the broadcast industry for improved efficiency and innovation.\"/><meta property=\"og:url\" content=\"https://sonicverse.eu/blog/broadcast-industry-has-software-problem\"/><meta property=\"og:type\" content=\"article\"/><meta property=\"article:published_time\" content=\"2026-04-13T13:45:00.276Z\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"The Broadcast Industry Has a Software Problem | Sonicverse\"/><meta name=\"twitter:description\" content=\"Explore how open source solutions can resolve the software challenges in the broadcast industry for improved efficiency and innovation.\"/><link rel=\"shortcut icon\" href=\"/favicon.ico\"/><link rel=\"icon\" href=\"/favicon.ico\"/><link rel=\"icon\" href=\"/favicon.svg\" type=\"image/svg+xml\"/><link rel=\"icon\" href=\"/favicon-96x96.png\" sizes=\"96x96\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\" sizes=\"180x180\" type=\"image/png\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body>