xt-[0.72rem] font-medium tracking-[0.13em] uppercase transition-colors border-primary/40 bg-primary text-white backdrop-blur-sm backdrop-saturate-[1.4]\",\"children\":\"Blog\"}],[\"$\",\"div\",null,{\"className\":\"grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-end\",\"children\":[[\"$\",\"div\",null,{\"className\":\"space-y-5\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"hero-title max-w-5xl text-[2.6rem] sm:text-[3.8rem] lg:text-[4.45rem]\",\"children\":\"The Broadcast Industry Has a Software Problem\"}],[\"$\",\"p\",null,{\"className\":\"copy-lg max-w-2xl\",\"children\":\"Explore how open source solutions can resolve the software challenges in the broadcast industry for improved efficiency and innovation.\"}]]}],[\"$\",\"div\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"rounded-[1.7rem] border border-border/70 bg-[linear-gradient(180deg,var(--surface-1),var(--surface-2))] p-5 shadow-[var(--shadow-soft)] backdrop-blur-xl backdrop-saturate-[1.6]\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-3\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[0.7rem] font-medium tracking-[0.24em] uppercase text-foreground/44\",\"children\":\"Entry signal\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[\"$\",\"div\",null,{\"className\":\"inline-flex items-center rounded-full border px-3 py-1 text-[0.72rem] font-medium tracking-[0.13em] uppercase transition-colors border-border/70 bg-background/52 text-foreground/62 backdrop-blur-sm backdrop-saturate-[1.3]\",\"children\":\"Technical note\"}]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[\"$\",\"div\",\"Editorial\",{\"className\":\"inline-flex items-center rounded-full border px-3 py-1 text-[0.72rem] font-medium tracking-[0.13em] uppercase transition-colors border-border/70 bg-background/52 text-foreground/62 backdrop-blur-sm backdrop-saturate-[1.3]\",\"children\":\"Editorial\"}],[\"$\",\"div\",\"Open Source\",{\"className\":\"inline-flex items-center rounded-full border px-3 py-1 text-[0.72rem] font-medium tracking-[0.13em] uppercase transition-colors border-border/70 bg-background/52 text-foreground/62 backdrop-blur-sm backdrop-saturate-[1.3]\",\"children\":\"Open Source\"}],[\"$\",\"div\",\"Operations\",{\"className\":\"inline-flex items-center rounded-full border px-3 py-1 text-[0.72rem] font-medium tracking-[0.13em] uppercase transition-colors border-border/70 bg-background/52 text-foreground/62 backdrop-blur-sm backdrop-saturate-[1.3]\",\"children\":\"Operations\"}]]}]]}]}]}]]}]]}]}]}],[\"$\",\"section\",null,{\"className\":\"pb-24 sm:pb-28\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto w-full max-w-7xl px-5 sm:px-6 lg:px-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_300px] lg:items-start\",\"children\":[[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"article\",null,{\"className\":\"rounded-[2rem] border border-border/70 bg-[linear-gradient(180deg,var(--surface-1),var(--surface-2))] px-6 py-7 shadow-[var(--shadow-soft)] backdrop-blur-xl backdrop-saturate-[1.6] sm:px-8 sm:py-9\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-6\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"For decades, radio stations have relied on a small handful of proprietary vendors to power their infrastructure. Playout systems, scheduling tools, streaming servers — the choices were limited, the contracts long, and the pricing... let's say opaque. Broadcasters accepted this as the cost of doing business.\"}],\"\\n\",[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"$L1d\"}],\"\\n\",\"$L1e\",\"\\n\",\"$L1f\",\"\\n\",\"$L20\",\"\\n\",\"$L21\",\"\\n\",\"$L22\",\"\\n\",\"$L23\",\"\\n\",\"$L24\",\"\\n\",\"$L25\",\"\\n\",\"$L26\",\"\\n\",\"$L27\",\"\\n\",\"$L28\",\"\\n\",\"$L29\",\"\\n\",\"$L2a\",\"\\n\",\"$L2b\",\"\\n\",\"$L2c\",\"\\n\",\"$L2d\",\"\\n\",\"$L2e\",\"\\n\",\"$L2f\",\"\\n\",\"$L30\",\"\\n\",\"$L31\",\"\\n\",\"$L32\",\"\\n\",\"$L33\",\"\\n\",\"$L34\",\"\\n\",\"$L35\",\"\\n\",\"$L36\",\"\\n\",\"$L37\",\"\\n\",\"$L38\",\"\\n\",\"$L39\",\"\\n\",\"$L3a\"]}]}]}],\"$L3b\"]}]}]]\n16:null\n1b:[[\"$\",\"title\",\"0\",{\"children\":\"The Broadcast Industry Has a Software Problem - Sonicverse\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Explore how open source solutions can resolve the software challenges in the broadcast industry for improved efficiency and innovation.\"}],[\"$\",\"link\",\"2\",{\"rel\":\"manifest\",\"href\":\"/site.webmanifest\",\"crossOrigin\":\"$undefined\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://sonicverse.eu/blog/broadcast-industry-has-software-problem\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"The Broadcast Industry Has a Software Problem | Sonicverse\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"Explore how open source solutions can resolve the software challenges in the broadcast industry for improved efficiency and innovation.\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:url\",\"content\":\"https://sonicverse.eu/blog/broadcast-industry-has-software-problem\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"8\",{\"property\":\"article:published_time\",\"content\":\"2026-04-13T13:45:00.276Z\"}],[\"$\",\"meta\",\"9\",{\"name\":\"twitter:card\",\"content\":\"summary\"}],[\"$\",\"meta\",\"10\",{\"name\":\"twitter:title\",\"content\":\"The Broadcast Industry Has a Software Problem | Sonicverse\"}],[\"$\",\"meta\",\"11\",{\"name\":\"twitter:description\",\"content\":\"Explore how open source solutions can resolve the software challenges in the broadcast industry for improved efficiency and innovation.\"}],[\"$\",\"link\",\"12\",{\"rel\":\"shortcut icon\",\"href\":\"/favicon.ico\"}],[\"$\",\"link\",\"13\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\"}],[\"$\",\"link\",\"14\",{\"rel\":\"icon\",\"href\":\"/favicon.svg\",\"type\":\"image/svg+xml\"}],[\"$\",\"link\",\"15\",{\"rel\":\"icon\",\"href\":\"/favicon-96x96.png\",\"sizes\":\"96x96\",\"type\":\"image/png\"}],[\"$\",\"link\",\"16\",{\"rel\":\"apple-touch-icon\",\"href\":\"/apple-touch-icon.png\",\"sizes\":\"180x180\",\"type\":\"image/png\"}],[\"$\",\"$L3c\",\"17\",{}]]\n3d:I[58541,[\"/_next/static/chunks/148d-9g_w8i0~.js\",\"/_next/static/chunks/04mq052otkkl9.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0q77_8lbj.p8k.js\",\"/_next/static/chunks/08y1d-jmw72iw.js\"],\"default\"]\n1d:[\"$\",\"strong\",null,{\"children\":\"That era is ending.\"}]\n1e:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Open source software has quietly matured into a broadcast-ready force. The tools exist. The communities are active. And for stations willing to look beyond the legacy vendors, the upside is significant — not just financially, but strategically.\"}]\n1f:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"Why Broadcasting Stayed Behind\"}]\n20:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"The broadcast industry has always been conservative about technology adoption, and for understandable reasons. On-air reliability is non-negotiable. A software bug that crashes a CRM is an inconvenience. One that silences your station at 8am on a Monday is a crisis.\"}]\n21:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"This risk aversion made proprietary software appealing: someone else was accountable, there was a support number to call, and switching costs were high enough that vendors rarely disappeared overnight.\"}]\n22:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"But that model came with trade-offs that are increasingly hard to justify. Vendor lock-in means your roadmap is dictated by someone else's priorities. Licensing fees scale with your growth.\"}]\n23:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"And when a vendor sunsets a product or gets acquired, you're left scrambling.\"}]\n24:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Meanwhile, open source has been solving exactly these problems — for industries far more demanding than broadcasting.\"}]\n25:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"The Infrastructure Is Already There\"}]\n26:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"The Linux kernel runs the majority of the world's servers, including most broadcast infrastructure whether stations know it or not. FFmpeg — open source — is the backbone of virtually every audio and video processing pipeline on the planet. These aren't experimental tools. They're the foundation.\"}]\n27:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"The question is no longer whether open source can handle broadcast workloads. It clearly can. The question is whether your organisation is structured to take advantage of it.\"}]\n28:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"What \\\"Open Source First\\\" Looks Like in Practice\"}]\n29:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Adopting open source doesn't mean abandoning all vendor relationships or building everything from scratch. It means changing your default question from \\\"which vendor sells this?\\\" to \\\"does a good open solution exist first?\\\"\"}]\n2a:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"For station managers, this shifts budget conversations. Licensing costs that once felt fixed become variable. That money can be redirected toward people, content, or tooling that actually differentiates your station.\"}]\n2b:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"For technical teams, open source means access to the source code — which sounds obvious but has profound implications. You can fix bugs without waiting for a support ticket to be resolved. You can extend functionality to fit your exact workflow. You're not blocked by a vendor's quarterly release cycle when you need something now.\"}]\n2c:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"And critically: open source projects don't get acquired and sunset. The community owns the roadmap.\"}]\n2d:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"The Interoperability Advantage\"}]\n2e:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"One of the less-discussed benefits of open source in broadcasting is how well these tools play together. Proprietary systems are often designed with lock-in as a feature — APIs are limited, data formats are proprietary, integrations require expensive middleware.\"}]\n2f:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Open source tools, by contrast, are typically built around open standards. That means a scheduling system, a playout engine, a streaming server, and an analytics platform can be wired together in ways that genuinely serve your operational needs — not the vendor's upsell strategy.\"}]\n30:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"For broadcasters thinking about the next five years — more personalisation, smarter automation, tighter integration between on-air and digital — this interoperability isn't a nice-to-have. It's a prerequisite.\"}]\n31:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"What We're Building at Sonicverse\"}]\n32:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"We started Sonicverse because we felt the gap firsthand. As broadcasters and developers, we kept running into the same friction: tools that didn't talk to each other, vendor roadmaps that didn't reflect how stations actually work, and a lack of software built specifically for the realities of modern radio.\"}]\n33:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"So we're building it — in the open.\"}]\n34:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Sonicverse is early. We're not going to pretend otherwise. But the foundation is intentional: open source at the core, designed for broadcasters, built by people who understand the industry from the inside. We're developing tools that cover the parts of the broadcast workflow that have been underserved for too long — from show preparation to station management to infrastructure tooling.\"}]\n35:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"We're just getting started, and there's a lot ahead. But we believe the broadcast industry deserves software built with the same craft and ambition that goes into the content stations produce every day. We're here to build that.\"}]\n36:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"If you're a broadcaster curious about what we're working on, we'd love to hear from you.\"}]\n37:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"The Broadcast Industry of 2030\"}]\n38:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"The stations that will thrive over the next decade won't be the ones with the most expensive software contracts. They'll be the ones with the most flexible infrastructure, the fastest ability to adapt, and the lowest friction between an idea and its implementation.\"}]\n39:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Open source is how you build that. Not because it's free — though that helps — but because it puts you in control of your own stack, your own roadmap, and your own future.\"}]\n3a:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"The tools are ready. The only question is whether the industry is ready to use them.\"}]\n3b:[\"$\",\"$L1c\",null,{\"delay\":0.06,\"children\":[\"$\",\"div\",null,{\"className\":\"rounded-[1.7rem] border border-border/70 bg-[linear-gradient(180deg,var(--surface-1),var(--surface-2))] p-5 shadow-[var(--shadow-soft)] backdrop-blur-xl backdrop-saturate-[1.6] lg:sticky lg:top-28\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",\"Published-Apr 13, 2026\",{\"className\":\"space-y-3\",\"children\":[null,[\"$\",\"div\",null,{\"className\":\"flex items-start gap-3\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-0.5 flex size-8 items-center justify-center rounded-full border border-border/70 bg-background/50 text-foreground/64\",\"children\":[\"$\",\"$L3d\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"M8 2v4\",\"key\":\"1cmpym\"}],[\"path\",{\"d\":\"M16 2v4\",\"key\":\"4m81vk\"}],[\"rect\",{\"width\":\"18\",\"height\":\"18\",\"x\":\"3\",\"y\":\"4\",\"rx\":\"2\",\"key\":\"1hopcy\"}],[\"path\",{\"d\":\"M3 10h18\",\"key\":\"8toen8\"}],[\"path\",{\"d\":\"M8 14h.01\",\"key\":\"6423bh\"}],[\"path\",{\"d\":\"M12 14h.01\",\"key\":\"1etili\"}],[\"path\",{\"d\":\"M16 14h.01\",\"key\":\"1gbofw\"}],[\"path\",{\"d\":\"M8 18h.01\",\"key\":\"lrp35t\"}],[\"path\",{\"d\":\"M12 18h.01\",\"key\":\"mhygvu\"}],[\"path\",{\"d\":\"M16 18h.01\",\"key\":\"kzsmim\"}]],\"className\":\"lucide-calendar-days size-4\"}]}],[\"$\",\"div\",null,{\"className\":\"space-y-1\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[0.68rem] font-medium tracking-[0.22em] uppercase text-foreground/46\",\"children\":\"Published\"}],[\"$\",\"p\",null,{\"className\":\"text-sm leading-7 text-foreground/72\",\"children\":\"Apr 13, 2026\"}]]}]]}]]}]]}]}]}]\n","/blog/broadcast-industry-has-software-problem/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[94206,[\"/_next/static/chunks/148d-9g_w8i0~.js\",\"/_next/static/chunks/04mq052otkkl9.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0q77_8lbj.p8k.js\",\"/_next/static/chunks/08y1d-jmw72iw.js\"],\"Reveal\"]\n24:I[58541,[\"/_next/static/chunks/148d-9g_w8i0~.js\",\"/_next/static/chunks/04mq052otkkl9.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0q77_8lbj.p8k.js\",\"/_next/static/chunks/08y1d-jmw72iw.js\"],\"default\"]\n25:I[97367,[\"/_next/static/chunks/148d-9g_w8i0~.js\",\"/_next/static/chunks/04mq052otkkl9.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0q77_8lbj.p8k.js\"],\"OutletBoundary\"]\n26:\"$Sreact.suspense\"\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"section\",null,{\"className\":\"relative overflow-hidden pt-36 pb-12 sm:pt-40 sm:pb-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto w-full max-w-7xl px-5 sm:px-6 lg:px-8 relative space-y-8\",\"children\":[\"$\",\"$L2\",null,{\"className\":\"space-y-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"inline-flex items-center rounded-full border px-3 py-1 text-[0.72rem] font-medium tracking-[0.13em] uppercase transition-colors border-primary/40 bg-primary text-white backdrop-blur-sm backdrop-saturate-[1.4]\",\"children\":\"Blog\"}],[\"$\",\"div\",null,{\"className\":\"grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-end\",\"children\":[[\"$\",\"div\",null,{\"className\":\"space-y-5\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"hero-title max-w-5xl text-[2.6rem] sm:text-[3.8rem] lg:text-[4.45rem]\",\"children\":\"The Broadcast Industry Has a Software Problem\"}],[\"$\",\"p\",null,{\"className\":\"copy-lg max-w-2xl\",\"children\":\"Explore how open source solutions can resolve the software challenges in the broadcast industry for improved efficiency and innovation.\"}]]}],[\"$\",\"div\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"rounded-[1.7rem] border border-border/70 bg-[linear-gradient(180deg,var(--surface-1),var(--surface-2))] p-5 shadow-[var(--shadow-soft)] backdrop-blur-xl backdrop-saturate-[1.6]\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-3\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[0.7rem] font-medium tracking-[0.24em] uppercase text-foreground/44\",\"children\":\"Entry signal\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[\"$\",\"div\",null,{\"className\":\"inline-flex items-center rounded-full border px-3 py-1 text-[0.72rem] font-medium tracking-[0.13em] uppercase transition-colors border-border/70 bg-background/52 text-foreground/62 backdrop-blur-sm backdrop-saturate-[1.3]\",\"children\":\"Technical note\"}]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[\"$\",\"div\",\"Editorial\",{\"className\":\"inline-flex items-center rounded-full border px-3 py-1 text-[0.72rem] font-medium tracking-[0.13em] uppercase transition-colors border-border/70 bg-background/52 text-foreground/62 backdrop-blur-sm backdrop-saturate-[1.3]\",\"children\":\"Editorial\"}],[\"$\",\"div\",\"Open Source\",{\"className\":\"inline-flex items-center rounded-full border px-3 py-1 text-[0.72rem] font-medium tracking-[0.13em] uppercase transition-colors border-border/70 bg-background/52 text-foreground/62 backdrop-blur-sm backdrop-saturate-[1.3]\",\"children\":\"Open Source\"}],[\"$\",\"div\",\"Operations\",{\"className\":\"inline-flex items-center rounded-full border px-3 py-1 text-[0.72rem] font-medium tracking-[0.13em] uppercase transition-colors border-border/70 bg-background/52 text-foreground/62 backdrop-blur-sm backdrop-saturate-[1.3]\",\"children\":\"Operations\"}]]}]]}]}]}]]}]]}]}]}],[\"$\",\"section\",null,{\"className\":\"pb-24 sm:pb-28\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto w-full max-w-7xl px-5 sm:px-6 lg:px-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_300px] lg:items-start\",\"children\":[[\"$\",\"$L2\",null,{\"children\":[\"$\",\"article\",null,{\"className\":\"rounded-[2rem] border border-border/70 bg-[linear-gradient(180deg,var(--surface-1),var(--surface-2))] px-6 py-7 shadow-[var(--shadow-soft)] backdrop-blur-xl backdrop-saturate-[1.6] sm:px-8 sm:py-9\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-6\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"For decades, radio stations have relied on a small handful of proprietary vendors to power their infrastructure. Playout systems, scheduling tools, streaming servers — the choices were limited, the contracts long, and the pricing... let's say opaque. Broadcasters accepted this as the cost of doing business.\"}],\"\\n\",\"$L3\",\"\\n\",\"$L4\",\"\\n\",\"$L5\",\"\\n\",\"$L6\",\"\\n\",\"$L7\",\"\\n\",\"$L8\",\"\\n\",\"$L9\",\"\\n\",\"$La\",\"\\n\",\"$Lb\",\"\\n\",\"$Lc\",\"\\n\",\"$Ld\",\"\\n\",\"$Le\",\"\\n\",\"$Lf\",\"\\n\",\"$L10\",\"\\n\",\"$L11\",\"\\n\",\"$L12\",\"\\n\",\"$L13\",\"\\n\",\"$L14\",\"\\n\",\"$L15\",\"\\n\",\"$L16\",\"\\n\",\"$L17\",\"\\n\",\"$L18\",\"\\n\",\"$L19\",\"\\n\",\"$L1a\",\"\\n\",\"$L1b\",\"\\n\",\"$L1c\",\"\\n\",\"$L1d\",\"\\n\",\"$L1e\",\"\\n\",\"$L1f\",\"\\n\",\"$L20\"]}]}]}],\"$L21\"]}]}]],[\"$L22\"],\"$L23\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"GVWyDEb3PM1EXG4IIfDc8\"}\n3:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":[\"$\",\"strong\",null,{\"children\":\"That era is ending.\"}]}]\n4:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Open source software has quietly matured into a broadcast-ready force. The tools exist. The communities are active. And for stations willing to look beyond the legacy vendors, the upside is significant — not just financially, but strategically.\"}]\n5:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"Why Broadcasting Stayed Behind\"}]\n6:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"The broadcast industry has always been conservative about technology adoption, and for understandable reasons. On-air reliability is non-negotiable. A software bug that crashes a CRM is an inconvenience. One that silences your station at 8am on a Monday is a crisis.\"}]\n7:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"This risk aversion made proprietary software appealing: someone else was accountable, there was a support number to call, and switching costs were high enough that vendors rarely disappeared overnight.\"}]\n8:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"But that model came with trade-offs that are increasingly hard to justify. Vendor lock-in means your roadmap is dictated by someone else's priorities. Licensing fees scale with your growth.\"}]\n9:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"And when a vendor sunsets a product or gets acquired, you're left scrambling.\"}]\na:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Meanwhile, open source has been solving exactly these problems — for industries far more demanding than broadcasting.\"}]\nb:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"The Infrastructure Is Already There\"}]\nc:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"The Linux kernel runs the majority of the world's servers, including most broadcast infrastructure whether stations know it or not. FFmpeg — open source — is the backbone of virtually every audio and video processing pipeline on the planet. These aren't experimental tools. They're the foundation.\"}]\nd:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"The question is no longer whether open source can handle broadcast workloads. It clearly can. The question is whether your organisation is structured to take advantage of it.\"}]\ne:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"What \\\"Open Source First\\\" Looks Like in Practice\"}]\nf:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Adopting open source doesn't mean abandoning all vendor relationships or building everything from scratch. It means changing your default question from \\\"which vendor sells this?\\\" to \\\"does a good open solution exist first?\\\"\"}]\n10:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"For station managers, this shifts budget conversations. Licensing costs that once felt fixed become variable. That money can be redirected toward people, content, or tooling that actually differentiates your station.\"}]\n11:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"For technical teams, open source means access to the source code — which sounds obvious but has profound implications. You can fix bugs without waiting for a support ticket to be resolved. You can extend functionality to fit your exact workflow. You're not blocked by a vendor's quarterly release cycle when you need something now.\"}]\n12:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"And critically: open source projects don't get acquired and sunset. The community owns the roadmap.\"}]\n13:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"The Interoperability Advantage\"}]\n14:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"One of the less-discussed benefits of open source in broadcasting is how well these tools play together. Proprietary systems are often designed with lock-in as a feature — APIs are limited, data formats are proprietary, integrations require expensive middleware.\"}]\n15:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Open source tools, by contrast, are typically built around open standards. That means a scheduling system, a playout engine, a streaming server, and an analytics platform can be wired together in ways that genuinely serve your operational needs — not the vendor's upsell strategy.\"}]\n16:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"For broadcasters thinking about the next five years — more personalisation, smarter automation, tighter integration between on-air and digital — this interoperability isn't a nice-to-have. It's a prerequisite.\"}]\n17:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"What We're Building at Sonicverse\"}]\n18:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"We started Sonicverse because we felt the gap firsthand. As broadcasters and developers, we kept running into the same friction: tools that didn't talk to each other, vendor roadmaps that didn't reflect how stations actually work, and a lack of software built specifically for the realities of modern radio.\"}]\n19:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"So we're building it — in the open.\"}]\n1a:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Sonicverse is early. We're not going to pretend otherwise. But the foundation is intentional: open source at the core, designed for broadcasters, built by people who understand the industry from the inside. We're developing tools that cover the parts of the broadcast workflow that have been underserved for too long — from show preparation to station management to infrastructure tooling.\"}]\n1b:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"We're just getting started, and there's a lot ahead. But we believe the broadcast industry deserves software built with the same craft and ambition that goes into the content stations produce every day. We're here to build that.\"}]\n1c:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"If you're a broadcaster curious about what we're working on, we'd love to hear from you.\"}]\n1d:[\"$\",\"h2\",null,{\"className\":\"pt-6 text-[1.65rem] font-semibold tracking-[-0.06em] text-foreground sm:text-[1.95rem]\",\"children\":\"The Broadcast Industry of 2030\"}]\n1e:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"The stations that will thrive over the next decade won't be the ones with the most expensive software contracts. They'll be the ones with the most flexible infrastructure, the fastest ability to adapt, and the lowest friction between an idea and its implementation.\"}]\n1f:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"Open source is how you build that. Not because it's free — though that helps — but because it puts you in control of your own stack, your own roadmap, and your own future.\"}]\n20:[\"$\",\"p\",null,{\"className\":\"text-[0.98rem] leading-8 text-foreground/72\",\"children\":\"The tools are ready. The only question is whether the industry is ready to use them.\"}]\n21:[\"$\",\"$L2\",null,{\"delay\":0.06,\"children\":[\"$\",\"div\",null,{\"className\":\"rounded-[1.7rem] border border-border/70 bg-[linear-gradient(180deg,var(--surface-1),var(--surface-2))] p-5 shadow-[var(--shadow-soft)] backdrop-blur-xl backdrop-saturate-[1.6] lg:sticky lg:top-28\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",\"Published-Apr 13, 2026\",{\"className\":\"space-y-3\",\"children\":[null,[\"$\",\"div\",null,{\"className\":\"flex items-start gap-3\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-0.5 flex size-8 items-center justify-center rounded-full border border-border/70 bg-background/50 text-foreground/64\",\"children\":[\"$\",\"$L24\",null,{\"iconNode\":[[\"path\",{\"d\":\"M8 2v4\",\"key\":\"1cmpym\"}],[\"path\",{\"d\":\"M16 2v4\",\"key\":\"4m81vk\"}],[\"rect\",{\"width\":\"18\",\"height\":\"18\",\"x\":\"3\",\"y\":\"4\",\"rx\":\"2\",\"key\":\"1hopcy\"}],[\"path\",{\"d\":\"M3 10h18\",\"key\":\"8toen8\"}],[\"path\",{\"d\":\"M8 14h.01\",\"key\":\"6423bh\"}],[\"path\",{\"d\":\"M12 14h.01\",\"key\":\"1etili\"}],[\"path\",{\"d\":\"M16 14h.01\",\"key\":\"1gbofw\"}],[\"path\",{\"d\":\"M8 18h.01\",\"key\":\"lrp35t\"}],[\"path\",{\"d\":\"M12 18h.01\",\"key\":\"mhygvu\"}],[\"path\",{\"d\":\"M16 18h.01\",\"key\":\"kzsmim\"}]],\"className\":\"lucide-calendar-days size-4\"}]}],[\"$\",\"div\",null,{\"className\":\"space-y-1\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[0.68rem] font-medium tracking-[0.22em] uppercase text-foreground/46\",\"children\":\"Published\"}],[\"$\",\"p\",null,{\"className\":\"text-sm leading-7 text-foreground/72\",\"children\":\"Apr 13, 2026\"}]]}]]}]]}]]}]}]}]\n22:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/08y1d-jmw72iw.js\",\"async\":true}]\n23:[\"$\",\"$L25\",null,{\"children\":[\"$\",\"$26\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@27\"}]}]\n27:null\n","/blog/broadcast-industry-has-software-problem":"1:\"$Sreact.fragment\"\n2:I[39756,[\"/_next/static/chunks/148d-9g_w8i0~.js\",\"/_next/static/chunks/04mq052otkkl9.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0q77_8lbj.p8k.js\"],\"default\"]\n3:I[37457,[\"/_next/static/chunks/148d-9g_w8i0~.js\",\"/_next/static/chunks/04mq052otkkl9.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0q77_8lbj.p8k.js\"],\"default\"]\n4:[]\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"template\":[\"$\",\"$L3\",null,{}]}]]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":\"$W4\",\"buildId\":\"GVWyDEb3PM1EXG4IIfDc8\"}\n","/blog":"1:\"$Sreact.fragment\"\n2:I[39756,[\"/_next/static/chunks/148d-9g_w8i0~.js\",\"/_next/static/chunks/04mq052otkkl9.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0q77_8lbj.p8k.js\"],\"default\"]\n3:I[37457,[\"/_next/static/chunks/148d-9g_w8i0~.js\",\"/_next/static/chunks/04mq052otkkl9.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0q77_8lbj.p8k.js\"],\"default\"]\n4:[]\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"template\":[\"$\",\"$L3\",null,{}]}]]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":\"$W4\",\"buildId\":\"GVWyDEb3PM1EXG4IIfDc8\"}\n","/_index":"1:\"$Sreact.fragment\"\n2:I[89554,[\"/_next/static/chunks/148d-9g_w8i0~.js\",\"/_next/static/chunks/04mq052otkkl9.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0q77_8l