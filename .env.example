# Public base URL for the image worker used by next/image.
# Leave unset when the worker is served from the same origin at /workers/image.
NEXT_PUBLIC_IMAGE_WORKER_URL="https://sonicverse.eu/workers/image"

# Email sender/recipient for contact form delivery
EMAIL_SENDER=noreply@mail.sonicverse.eu
EMAIL_RECIPIENT=hello@sonicverse.eu

# Alternatively, deploy with a Cloudflare Email Workers `send_email` binding
# named `SEND_EMAIL`. When present the app will use that binding to send messages.
