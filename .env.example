# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address (must be a verified domain in Resend)
RESEND_FROM=Sonicverse <hello@sonicverse.eu>

# Recipient — where contact form submissions are delivered
RESEND_TO=hello@sonicverse.eu

# Alternative: Cloudflare Email Workers `send_email` binding
# If you deploy with a `send_email` binding named `SEND_EMAIL`, the app will use
# that binding to send messages and you do not need `RESEND_API_KEY`.
